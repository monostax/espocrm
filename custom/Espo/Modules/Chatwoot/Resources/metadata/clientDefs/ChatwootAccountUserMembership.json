{
    "controller": "controllers/record",
    "iconClass": "ti ti-user-shield",
    "modelDefaultsPreparator": "chatwoot:handlers/chatwoot-account-user-membership/defaults-preparator",
    "defaultSidePanelFieldList": ["teams"],
    "viewSetupHandlers": {
        "record/detail": [
            "chatwoot:handlers/chatwoot-account-user-membership/record-detail-setup"
        ],
        "record/edit": [
            "chatwoot:handlers/chatwoot-account-user-membership/record-detail-setup"
        ]
    },
    "detailActionList": [
        {
            "name": "enableAiProfile",
            "label": "Enable AI Profile",
            "handler": "chatwoot:handlers/chatwoot-account-user-membership/detail-actions",
            "actionFunction": "enableAiProfile",
            "checkVisibilityFunction": "isEnableAiProfileAvailable",
            "groupIndex": 0
        },
        {
            "name": "disableAiProfile",
            "label": "Disable AI Profile",
            "handler": "chatwoot:handlers/chatwoot-account-user-membership/detail-actions",
            "actionFunction": "disableAiProfile",
            "checkVisibilityFunction": "isDisableAiProfileAvailable",
            "groupIndex": 1
        }
    ],
    "dynamicLogic": {
        "fields": {
            "role": {
                "readOnly": {
                    "conditionGroup": [
                        {
                            "type": "isNotEmpty",
                            "attribute": "id"
                        }
                    ]
                }
            }
        },
        "panels": {
            "aiProfile": {
                "visible": {
                    "conditionGroup": [
                        {
                            "type": "isNotEmpty",
                            "attribute": "chatwootAgentId"
                        }
                    ]
                }
            }
        }
    },
    "bottomPanels": {
        "detail": [
            {
                "name": "chatwootInboxes",
                "label": "Inboxes",
                "view": "views/record/panels/relationship",
                "select": true,
                "create": false,
                "rowActionsView": "views/record/row-actions/relationship-view-and-unlink",
                "order": 5,
                "disabled": false
            }
        ]
    },
    "relationshipPanels": {
        "chatwootInboxes": {
            "select": true,
            "create": false
        }
    }
}
