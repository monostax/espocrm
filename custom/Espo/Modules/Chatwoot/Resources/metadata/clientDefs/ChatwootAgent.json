{
    "controller": "controllers/record",
    "iconClass": "ti ti-user-pentagon",
    "kanbanViewMode": false,
    "modalViews": {
        "detail": "views/modals/detail"
    },
    "recordViews": {
        "list": "views/record/list"
    },
    "filterList": ["all", "available", "offline", "administrators"],
    "boolFilterList": [],
    "dynamicLogic": {
        "fields": {
            "aiPrompt": {
                "visible": {
                    "conditionGroup": [
                        {
                            "type": "isTrue",
                            "attribute": "isAI"
                        }
                    ]
                }
            },
            "knowledgeBaseCategories": {
                "visible": {
                    "conditionGroup": [
                        {
                            "type": "isTrue",
                            "attribute": "isAI"
                        }
                    ]
                }
            },
            "calendarsToManage": {
                "visible": {
                    "conditionGroup": [
                        {
                            "type": "isTrue",
                            "attribute": "isAI"
                        }
                    ]
                }
            },
            "transferScenarios": {
                "visible": {
                    "conditionGroup": [
                        {
                            "type": "isTrue",
                            "attribute": "contextualTransferIsEnabled"
                        }
                    ]
                },
                "required": {
                    "conditionGroup": [
                        {
                            "type": "isTrue",
                            "attribute": "contextualTransferIsEnabled"
                        }
                    ]
                }
            }
        }
    },
    "viewSetupHandlers": {
        "record/detail": [
            "chatwoot:handlers/chatwoot-agent/record-detail-setup"
        ],
        "record/edit": ["chatwoot:handlers/chatwoot-agent/record-detail-setup"]
    },
    "bottomPanels": {
        "detail": [
            {
                "name": "chatwootTeams",
                "label": "Chat / Teams",
                "view": "views/record/panels/relationship",
                "select": true,
                "create": false,
                "rowActionsView": "views/record/row-actions/relationship-view-and-unlink",
                "order": 5,
                "disabled": false
            }
        ]
    },
    "relationshipPanels": {
        "chatwootTeams": {
            "create": false,
            "select": true,
            "view": "views/record/panels/relationship"
        }
    }
}
