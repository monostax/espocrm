{
    "controller": "controllers/record",
    "iconClass": "fas fa-prescription",
    "nameAttribute": "id",
    "defaultSidePanelFieldLists": {
        "detail": ["status", "tipo", "teams", "createdAt", "modifiedAt"],
        "edit": ["teams"],
        "detailSmall": ["teams"]
    },
    "relationshipPanels": {
        "itens": {
            "create": true,
            "select": false
        }
    },
    "filterList": [
        {
            "name": "status"
        },
        {
            "name": "tipo"
        }
    ],
    "dynamicLogic": {
        "fields": {
            "paciente": {
                "readOnly": {
                    "conditionGroup": [
                        {
                            "type": "in",
                            "attribute": "status",
                            "value": ["Expirada", "Cancelada"]
                        }
                    ]
                }
            },
            "medico": {
                "readOnly": {
                    "conditionGroup": [
                        {
                            "type": "in",
                            "attribute": "status",
                            "value": ["Expirada", "Cancelada"]
                        }
                    ]
                }
            },
            "unidade": {
                "readOnly": {
                    "conditionGroup": [
                        {
                            "type": "in",
                            "attribute": "status",
                            "value": ["Expirada", "Cancelada"]
                        }
                    ]
                }
            },
            "dataEmissao": {
                "readOnly": {
                    "conditionGroup": [
                        {
                            "type": "in",
                            "attribute": "status",
                            "value": ["Expirada", "Cancelada"]
                        }
                    ]
                }
            },
            "dataValidade": {
                "readOnly": {
                    "conditionGroup": [
                        {
                            "type": "in",
                            "attribute": "status",
                            "value": ["Expirada", "Cancelada"]
                        }
                    ]
                }
            },
            "tipo": {
                "readOnly": {
                    "conditionGroup": [
                        {
                            "type": "in",
                            "attribute": "status",
                            "value": ["Expirada", "Cancelada"]
                        }
                    ]
                }
            },
            "observacoes": {
                "readOnly": {
                    "conditionGroup": [
                        {
                            "type": "in",
                            "attribute": "status",
                            "value": ["Expirada", "Cancelada"]
                        }
                    ]
                }
            }
        }
    }
