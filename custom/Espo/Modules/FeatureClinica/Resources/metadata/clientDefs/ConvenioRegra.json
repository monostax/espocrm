{
    "controller": "controllers/record",
    "iconClass": "fas fa-balance-scale",
    "nameAttribute": "id",
    "filterList": ["cobertura", "requerAutorizacao"],
    "dynamicLogic": {
        "fields": {
            "percentualCobertura": {
                "visible": {
                    "conditionGroup": [
                        {
                            "type": "equals",
                            "attribute": "cobertura",
                            "value": "Parcial"
                        }
                    ]
                }
            },
            "valorFixo": {
                "visible": {
                    "conditionGroup": [
                        {
                            "type": "equals",
                            "attribute": "cobertura",
                            "value": "Parcial"
                        }
                    ]
                }
            },
            "limiteAnual": {
                "visible": {
                    "conditionGroup": [
                        {
                            "type": "in",
                            "attribute": "cobertura",
                            "value": ["Total", "Parcial"]
                        }
                    ]
                }
            }
        }
    }
}
