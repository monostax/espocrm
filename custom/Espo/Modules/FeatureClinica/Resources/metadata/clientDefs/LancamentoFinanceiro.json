{
    "controller": "controllers/record",
    "iconClass": "fas fa-money-check-alt",
    "nameAttribute": "id",
    "defaultSidePanelFieldLists": {
        "detail": ["status", "tipo", "paciente", "unidade", "convenio", "teams", "createdAt", "modifiedAt"],
        "edit": ["teams"],
        "detailSmall": ["teams"]
    },
    "filterList": [
        {
            "name": "status"
        },
        {
            "name": "tipo"
        },
        {
            "name": "formaPagamento"
        },
        {
            "name": "unidade"
        },
        {
            "name": "convenio"
        }
    ],
    "dynamicLogic": {
        "fields": {
            "autorizadoPor": {
                "required": {
                    "conditionGroup": [
                        {
                            "type": "isNotEmpty",
                            "attribute": "valorDesconto"
                        }
                    ]
                }
            },
            "percentualConvenio": {
                "visible": {
                    "conditionGroup": [
                        {
                            "type": "isNotEmpty",
                            "attribute": "convenioId"
                        }
                    ]
                }
            },
            "valorConvenio": {
                "visible": {
                    "conditionGroup": [
                        {
                            "type": "isNotEmpty",
                            "attribute": "convenioId"
                        }
                    ]
                }
            },
            "valorPaciente": {
                "visible": {
                    "conditionGroup": [
                        {
                            "type": "isNotEmpty",
                            "attribute": "convenioId"
                        }
                    ]
                }
            },
            "dataPagamento": {
                "visible": {
                    "conditionGroup": [
                        {
                            "type": "equals",
                            "attribute": "status",
                            "value": "Pago"
                        }
                    ]
                }
            },
            "parcelas": {
                "visible": {
                    "conditionGroup": [
                        {
                            "type": "in",
                            "attribute": "formaPagamento",
                            "value": ["Cartao", "Boleto"]
                        }
                    ]
                }
            }
        }
    }
}
