{
    "controller": "controllers/record",
    "iconClass": "fas fa-user-md",
    "nameAttribute": "nome",
    "defaultSidePanelFieldLists": {
        "detail": ["ativo", "tipoProfissional", "user", "teams", "createdAt", "modifiedAt"],
        "edit": ["teams"],
        "detailSmall": ["teams"]
    },
    "relationshipPanels": {
        "appointments": {
            "create": false,
            "select": false,
            "filterList": ["status"]
        },
        "atendimentos": {
            "create": false,
            "select": false,
            "filterList": ["status"]
        },
        "jornadas": {
            "create": false,
            "select": false,
            "filterList": ["status"]
        },
        "prescricoes": {
            "create": false,
            "select": false,
            "filterList": ["status"]
        },
        "prontuarios": {
            "create": false,
            "select": false
        },
        "anamneses": {
            "create": false,
            "select": false
        }
    },
    "filterList": ["ativo", "tipoProfissional"],
    "dynamicLogic": {
        "fields": {
            "crm": {
                "required": {
                    "conditionGroup": [
                        {
                            "type": "isTrue",
                            "attribute": "tipoProfissionalRequerCRM"
                        }
                    ]
                }
            },
            "crmUf": {
                "required": {
                    "conditionGroup": [
                        {
                            "type": "isTrue",
                            "attribute": "tipoProfissionalRequerCRM"
                        }
                    ]
                }
            }
        }
    }
}
