            "select": false,
            "filterList": [
                {"name": "ativo"}
            ]
        },
        "convenioRegras": {
            "create": false,
            "select": false,
            "filterList": [
                {"name": "cobertura"}
            ]
        },
        "programaItens": {
            "create": false,
            "select": false
        }
    },
    "filterList": [
        {
            "name": "ativo"
        },
        {
            "name": "viaAdministracao"
        },
