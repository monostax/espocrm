{
    "controller": "controllers/record",
    "iconClass": "fas fa-stethoscope",
    "nameAttribute": "nome",
    "defaultSidePanelFieldLists": {
        "detail": ["ativo", "unidade", "valorBase", "teams", "createdAt", "modifiedAt"],
        "edit": ["teams"],
        "detailSmall": ["teams"]
    },
    "relationshipPanels": {
        "appointments": {
            "create": false,
            "select": false,
            "filterList": ["status"]
        },
        "sessoes": {
            "create": false,
            "select": false,
            "filterList": ["status"]
        },
        "procedimentosRealizados": {
            "create": false,
            "select": false
        },
        "tabelaDePrecos": {
            "create": false,
            "select": false,
            "filterList": ["ativo"]
        },
        "convenioRegras": {
            "create": false,
            "select": false,
            "filterList": ["cobertura"]
        },
        "programaItens": {
            "create": false,
            "select": false
        },
        "prescricaoItens": {
            "create": false,
            "select": false
        },
        "consumoInsumoPadrao": {
            "create": true,
            "select": false
        }
    },
    "filterList": ["ativo", "especialidade", "unidade"],
    "dynamicLogic": {
        "fields": {
            "intervaloRetornoDias": {
                "visible": {
                    "conditionGroup": [
                        {
                            "type": "isTrue",
                            "attribute": "ehRetorno"
                        }
                    ]
                }
            }
        }
    }
}
