{
    "controller": "controllers/record",
    "iconClass": "fas fa-stethoscope",
    "nameAttribute": "nome",
    "defaultSidePanelFieldLists": {
        "detail": ["ativo", "unidade", "valorBase", "teams", "createdAt", "modifiedAt"],
        "edit": ["teams"],
        "detailSmall": ["teams"]
    },
    "relationshipPanels": {
        "appointments": {
            "create": false,
            "select": false,
            "filterList": [
                {"name": "status"}
            ]
        },
        "sessoes": {
            "create": false,
            "select": false,
            "filterList": [
                {"name": "status"}
            ]
        },
        "procedimentosRealizados": {
            "create": false,
            "select": false
        },
        "tabelaDePrecos": {
            "create": false,
            "select": false,
            "filterList": [
                {"name": "ativo"}
            ]
        },
        "convenioRegras": {
            "create": false,
            "select": false,
            "filterList": [
                {"name": "cobertura"}
            ]
        },
        "programaItens": {
            "create": false,
            "select": false
        },
        "prescricaoItens": {
            "create": false,
            "select": false
        }
    },
    "filterList": [
        {
            "name": "ativo"
        },
        {
            "name": "especialidade"
        },
        {
            "name": "unidade"
        }
    ],
    "dynamicLogic": {
        "fields": {
            "intervaloRetornoDias": {
                "visible": {
                    "conditionGroup": [
                        {
                            "type": "isTrue",
                            "attribute": "ehRetorno"
                        }
                    ]
                }
            }
        }
    }
}
