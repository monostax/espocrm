{
    "fields": {
        "name": {
            "type": "varchar",
            "notStorable": true,
            "readOnly": true,
            "select": {
                "select": "nome"
            },
            "order": {
                "order": [["nome", "{direction}"]]
            }
        },
        "paciente": {
            "type": "link",
            "required": true
        },
        "nome": {
            "type": "varchar",
            "required": true,
            "maxLength": 255,
            "trim": true
        },
        "tipo": {
            "type": "enum",
            "required": true,
            "options": ["Exame", "Foto", "Receita", "Laudo", "Contrato", "Outro"]
        },
        "subtipo": {
            "type": "varchar",
            "maxLength": 100,
            "trim": true
        },
        "arquivo": {
            "type": "file"
        },
        "dataDocumento": {
            "type": "date"
        },
        "profissional": {
            "type": "link"
        },
        "unidade": {
            "type": "link",
            "required": true
        },
        "origemType": {
            "type": "varchar",
            "maxLength": 100
        },
        "origemId": {
            "type": "foreignId"
        },
        "origem": {
            "type": "linkParent",
            "entityList": ["Atendimento", "Prescricao", "Anamnese", "Prontuario"]
        },
        "confidencial": {
            "type": "bool",
            "default": false
        },
        "observacao": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams",
            "layoutRelationshipsDisabled": true
        }
    },
    "links": {
        "paciente": {
            "type": "belongsTo",
            "entity": "Paciente",
            "foreign": "documentos"
        },
        "profissional": {
            "type": "belongsTo",
            "entity": "Profissional",
            "foreignName": "nome"
        },
        "unidade": {
            "type": "belongsTo",
            "entity": "Unidade",
            "foreignName": "nome"
        },
        "origem": {
            "type": "belongsToParent"
        },
        "prontuarios": {
            "type": "hasMany",
            "entity": "Prontuario",
            "relationName": "prontuarioDocumento",
            "foreign": "documentos"
        },
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc",
        "textFilterFields": ["nome", "subtipo"]
    },
    "indexes": {
        "pacienteId": {
            "columns": ["pacienteId"]
        },
        "profissionalId": {
            "columns": ["profissionalId"]
        },
        "unidadeId": {
            "columns": ["unidadeId"]
        },
        "origem": {
            "columns": ["origemType", "origemId"]
        },
        "tipo": {
            "columns": ["tipo"]
        },
        "dataDocumento": {
            "columns": ["dataDocumento"]
        }
    }
}
