{
    "fields": {
        "nome": {
            "type": "varchar",
            "required": true,
            "maxLength": 255,
            "trim": true
        },
        "descricao": {
            "type": "text"
        },
        "precoTotal": {
            "type": "currency",
            "required": true
        },
        "validadeDias": {
            "type": "int",
            "required": true
        },
        "unidade": {
            "type": "link"
        },
        "ativo": {
            "type": "bool",
            "default": true
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams",
            "layoutRelationshipsDisabled": true
        }
    },
    "links": {
        "unidade": {
            "type": "belongsTo",
            "entity": "Unidade",
            "foreignName": "nome"
        },
        "itens": {
            "type": "hasMany",
            "entity": "ProgramaItem",
            "foreign": "programa",
            "cascadeDelete": true
        },
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        }
    },
    "collection": {
        "orderBy": "nome",
        "order": "asc",
        "textFilterFields": ["nome"]
    },
    "indexes": {
        "unidadeId": {
            "columns": ["unidadeId"]
        },
        "ativo": {
            "columns": ["ativo"]
        }
    }
}
