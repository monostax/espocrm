{
    "fields": {
        "name": {
            "type": "varchar",
            "notStorable": true,
            "readOnly": true,
            "select": {
                "select": "nome"
            },
            "order": {
                "order": [["nome", "{direction}"]]
            }
        },
        "nome": {
            "type": "varchar",
            "required": true,
            "maxLength": 255,
            "trim": true
        },
        "descricao": {
            "type": "text"
        },
        "tipo": {
            "type": "enum",
            "required": true,
            "options": ["Medicamento", "Cosmetico", "Material", "Outro"]
        },
        "unidadeMedida": {
            "type": "enum",
            "required": true,
            "options": ["mg", "ml", "UI", "unidade", "caixa"]
        },
        "estoqueMinimo": {
            "type": "float"
        },
        "fornecedorPrincipal": {
            "type": "varchar",
            "maxLength": 255,
            "trim": true
        },
        "requerReceituario": {
            "type": "bool",
            "default": false
        },
        "ativo": {
            "type": "bool",
            "default": true
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams",
            "layoutRelationshipsDisabled": true
        }
    },
    "links": {
        "lotes": {
            "type": "hasMany",
            "entity": "InsumoLote",
            "foreign": "insumo"
        },
        "procedimentosInjetaveis": {
            "type": "hasMany",
            "entity": "ProcedimentoInjetavel",
            "foreign": "insumo"
        },
        "procedimentosImplante": {
            "type": "hasMany",
            "entity": "ProcedimentoImplante",
            "foreign": "insumo"
        },
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        }
    },
    "collection": {
        "orderBy": "nome",
        "order": "asc",
        "textFilterFields": ["nome", "descricao"]
    },
    "indexes": {
        "ativo": {
            "columns": ["ativo"]
        },
        "tipo": {
            "columns": ["tipo"]
        }
    }
}
