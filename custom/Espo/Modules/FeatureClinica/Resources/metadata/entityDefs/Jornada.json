{
    "fields": {
        "paciente": {
            "type": "link",
            "required": true
        },
        "unidade": {
            "type": "link",
            "required": true
        },
        "profissional": {
            "type": "link"
        },
        "convenio": {
            "type": "link"
        },
        "status": {
            "type": "enum",
            "options": ["EmAndamento", "Concluida", "Cancelada"],
            "default": "EmAndamento",
            "style": {
                "EmAndamento": "primary",
                "Concluida": "success",
                "Cancelada": "danger"
            }
        },
        "dataInicio": {
            "type": "date",
            "required": true
        },
        "dataFim": {
            "type": "date"
        },
        "descricao": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams",
            "layoutRelationshipsDisabled": true
        }
    },
    "links": {
        "paciente": {
            "type": "belongsTo",
            "entity": "Paciente",
            "foreign": "jornadas"
        },
        "unidade": {
            "type": "belongsTo",
            "entity": "Unidade",
            "foreignName": "nome"
        },
        "profissional": {
            "type": "belongsTo",
            "entity": "Profissional",
            "foreignName": "nome"
        },
        "convenio": {
            "type": "belongsTo",
            "entity": "Convenio"
        },
        "sessoes": {
            "type": "hasMany",
            "entity": "Sessao",
            "foreign": "jornada"
        },
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc",
        "textFilterFields": ["paciente", "descricao"]
    },
    "indexes": {
        "pacienteId": {
            "columns": ["pacienteId"]
        },
        "unidadeId": {
            "columns": ["unidadeId"]
        },
        "profissionalId": {
            "columns": ["profissionalId"]
        },
        "status": {
            "columns": ["status"]
        }
    },
    "cascadeDelete": {
        "links": ["sessoes"]
    }
}
