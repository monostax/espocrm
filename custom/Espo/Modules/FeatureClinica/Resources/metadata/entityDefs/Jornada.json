{
    "fields": {
        "name": {
            "type": "varchar",
            "notStorable": true,
            "readOnly": true,
            "select": {
                "select": "nome"
            },
            "order": {
                "order": [["nome", "{direction}"]]
            }
        },
        "nome": {
            "type": "varchar",
            "required": true,
            "maxLength": 255,
            "trim": true
        },
        "paciente": {
            "type": "link",
            "required": true
        },
        "unidade": {
            "type": "link",
            "required": true
        },
        "profissional": {
            "type": "link"
        },
        "convenio": {
            "type": "link"
        },
        "programa": {
            "type": "link"
        },
        "status": {
            "type": "enum",
            "options": ["EmAndamento", "Pausada", "Concluida", "Abandonada", "Cancelada"],
            "default": "EmAndamento",
            "style": {
                "EmAndamento": "primary",
                "Pausada": "warning",
                "Concluida": "success",
                "Abandonada": "danger",
                "Cancelada": "danger"
            }
        },
        "dataInicio": {
            "type": "date",
            "required": true
        },
        "dataFim": {
            "type": "date"
        },
        "dataExpiracao": {
            "type": "date"
        },
        "objetivo": {
            "type": "text"
        },
        "descricao": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams",
            "layoutRelationshipsDisabled": true
        }
    },
    "links": {
        "paciente": {
            "type": "belongsTo",
            "entity": "Paciente",
            "foreign": "jornadas"
        },
        "unidade": {
            "type": "belongsTo",
            "entity": "Unidade",
            "foreignName": "nome"
        },
        "profissional": {
            "type": "belongsTo",
            "entity": "Profissional",
            "foreignName": "nome"
        },
        "convenio": {
            "type": "belongsTo",
            "entity": "Convenio",
            "foreignName": "nome"
        },
        "programa": {
            "type": "belongsTo",
            "entity": "Programa",
            "foreignName": "nome"
        },
        "sessoes": {
            "type": "hasMany",
            "entity": "Sessao",
            "foreign": "jornada"
        },
        "anamneses": {
            "type": "hasMany",
            "entity": "Anamnese",
            "foreign": "jornada"
        },
        "prontuarios": {
            "type": "hasMany",
            "entity": "Prontuario",
            "foreign": "jornada"
        },
        "lancamentosFinanceiros": {
            "type": "hasChildren",
            "entity": "LancamentoFinanceiro",
            "foreign": "origem"
        },
        "orcamentos": {
            "type": "hasMany",
            "entity": "Orcamento",
            "foreign": "jornada"
        },
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc",
        "textFilterFields": ["nome", "paciente", "descricao"]
    },
    "indexes": {
        "pacienteId": {
            "columns": ["pacienteId"]
        },
        "unidadeId": {
            "columns": ["unidadeId"]
        },
        "profissionalId": {
            "columns": ["profissionalId"]
        },
        "status": {
            "columns": ["status"]
        },
        "convenioId": {
            "columns": ["convenioId"]
        },
        "programaId": {
            "columns": ["programaId"]
        }
    },
    "cascadeDelete": {
        "links": ["sessoes"]
    }
}
