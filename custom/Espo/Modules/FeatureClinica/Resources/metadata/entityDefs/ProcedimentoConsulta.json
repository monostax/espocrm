{
    "fields": {
        "nome": {
            "type": "varchar",
            "required": true,
            "maxLength": 255,
            "trim": true
        },
        "codigo": {
            "type": "varchar",
            "maxLength": 50,
            "trim": true
        },
        "descricao": {
            "type": "text"
        },
        "duracaoMin": {
            "type": "int",
            "default": 30
        },
        "unidade": {
            "type": "link"
        },
        "valorBase": {
            "type": "currency"
        },
        "ativo": {
            "type": "bool",
            "default": true
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams",
            "layoutRelationshipsDisabled": true
        }
    },
    "links": {
        "unidade": {
            "type": "belongsTo",
            "entity": "Unidade",
            "foreignName": "nome"
        },
        "appointments": {
            "type": "hasChildren",
            "entity": "Appointment",
            "foreign": "procedimento"
        },
        "sessoes": {
            "type": "hasChildren",
            "entity": "Sessao",
            "foreign": "procedimento"
        },
        "procedimentosRealizados": {
            "type": "hasChildren",
            "entity": "ProcedimentoRealizado",
            "foreign": "procedimento"
        },
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        }
    },
    "collection": {
        "orderBy": "nome",
        "order": "asc",
        "textFilterFields": ["nome", "codigo"]
    },
    "indexes": {
        "unidadeId": {
            "columns": ["unidadeId"]
        },
        "ativo": {
            "columns": ["ativo"]
        },
        "codigo": {
            "unique": true,
            "columns": ["codigo", "deleted"]
        }
    }
}
