{
    "fields": {
        "name": {
            "type": "varchar",
            "notStorable": true,
            "readOnly": true,
            "select": {
                "select": "nome"
            },
            "order": {
                "order": [["nome", "{direction}"]]
            }
        },
        "nome": {
            "type": "varchar",
            "required": true,
            "maxLength": 255,
            "trim": true
        },
        "subtipo": {
            "type": "enum",
            "required": true,
            "options": ["Corporal", "Facial", "Capilar", "Outro"]
        },
        "duracaoMin": {
            "type": "int",
            "required": true
        },
        "equipamentoNecessario": {
            "type": "varchar",
            "maxLength": 255,
            "trim": true
        },
        "requerAvaliacaoPrevia": {
            "type": "bool",
            "default": false
        },
        "maximoSessoesSemana": {
            "type": "int"
        },
        "unidade": {
            "type": "link"
        },
        "ativo": {
            "type": "bool",
            "default": true
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams",
            "layoutRelationshipsDisabled": true
        }
    },
    "links": {
        "unidade": {
            "type": "belongsTo",
            "entity": "Unidade",
            "foreignName": "nome"
        },
        "appointments": {
            "type": "hasChildren",
            "entity": "Appointment",
            "foreign": "procedimento"
        },
        "sessoes": {
            "type": "hasChildren",
            "entity": "Sessao",
            "foreign": "procedimento"
        },
        "procedimentosRealizados": {
            "type": "hasChildren",
            "entity": "ProcedimentoRealizado",
            "foreign": "procedimento"
        },
        "tabelaDePrecos": {
            "type": "hasChildren",
            "entity": "TabelaDePrecos",
            "foreign": "procedimento"
        },
        "convenioRegras": {
            "type": "hasChildren",
            "entity": "ConvenioRegra",
            "foreign": "procedimento"
        },
        "programaItens": {
            "type": "hasChildren",
            "entity": "ProgramaItem",
            "foreign": "procedimento"
        },
        "prescricaoItens": {
            "type": "hasChildren",
            "entity": "PrescricaoItem",
            "foreign": "procedimento"
        },
        "orcamentoItens": {
            "type": "hasChildren",
            "entity": "OrcamentoItem",
            "foreign": "procedimento"
        },
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        }
    },
    "collection": {
        "orderBy": "nome",
        "order": "asc",
        "textFilterFields": ["nome"]
    },
    "indexes": {
        "unidadeId": {
            "columns": ["unidadeId"]
        },
        "ativo": {
            "columns": ["ativo"]
        }
    }
}
