{
    "fields": {
        "orcamento": {
            "type": "link",
            "required": true
        },
        "procedimentoType": {
            "type": "varchar",
            "maxLength": 100
        },
        "procedimentoId": {
            "type": "foreignId"
        },
        "procedimento": {
            "type": "linkParent",
            "entityList": ["ProcedimentoConsulta", "ProcedimentoInjetavel", "ProcedimentoImplante", "ProcedimentoEstetico", "ProcedimentoAtividadeFisica"]
        },
        "quantidade": {
            "type": "int",
            "required": true
        },
        "valorUnitario": {
            "type": "currency",
            "required": true
        },
        "valorTotal": {
            "type": "currency",
            "required": true
        },
        "desconto": {
            "type": "float"
        },
        "valorComDesconto": {
            "type": "currency"
        },
        "dosagemPorSessao": {
            "type": "float"
        },
        "unidadeDosagem": {
            "type": "link"
        },
        "observacao": {
            "type": "varchar",
            "maxLength": 255,
            "trim": true
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams",
            "layoutRelationshipsDisabled": true
        }
    },
    "links": {
        "orcamento": {
            "type": "belongsTo",
            "entity": "Orcamento",
            "foreign": "itens",
            "foreignName": "numero"
        },
        "procedimento": {
            "type": "belongsToParent"
        },
        "unidadeDosagem": {
            "type": "belongsTo",
            "entity": "UnidadeDosagem",
            "foreignName": "nome"
        },
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "asc"
    },
    "indexes": {
        "orcamentoId": {
            "columns": ["orcamentoId"]
        },
        "procedimento": {
            "columns": ["procedimentoType", "procedimentoId"]
        }
    }
}
