{
    "fields": {
        "atendimento": {
            "type": "link",
            "required": true
        },
        "procedimentoType": {
            "type": "varchar",
            "maxLength": 100
        },
        "procedimentoId": {
            "type": "foreignId"
        },
        "procedimento": {
            "type": "linkParent",
            "entityList": ["ProcedimentoConsulta", "ProcedimentoInjetavel", "ProcedimentoImplante", "ProcedimentoEstetico", "ProcedimentoAtividadeFisica"]
        },
        "sessao": {
            "type": "link"
        },
        "quantidade": {
            "type": "int",
            "default": 1
        },
        "valorCobrado": {
            "type": "currency"
        },
        "dosagemAplicada": {
            "type": "float"
        },
        "unidadeDosagem": {
            "type": "link"
        },
        "insumoLote": {
            "type": "link"
        },
        "observacao": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams",
            "layoutRelationshipsDisabled": true
        }
    },
    "links": {
        "atendimento": {
            "type": "belongsTo",
            "entity": "Atendimento",
            "foreign": "procedimentosRealizados",
            "foreignName": "id"
        },
        "procedimento": {
            "type": "belongsToParent"
        },
        "sessao": {
            "type": "belongsTo",
            "entity": "Sessao",
            "foreignName": "id"
        },
        "unidadeDosagem": {
            "type": "belongsTo",
            "entity": "UnidadeDosagem",
            "foreignName": "nome"
        },
        "insumoLote": {
            "type": "belongsTo",
            "entity": "InsumoLote",
            "foreignName": "numeroLote"
        },
        "movimentacoesEstoque": {
            "type": "hasChildren",
            "entity": "MovimentacaoEstoque",
            "foreign": "origem"
        },
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc"
    },
    "indexes": {
        "procedimento": {
            "columns": ["procedimentoType", "procedimentoId"]
        },
        "atendimentoId": {
            "columns": ["atendimentoId"]
        },
        "sessaoId": {
            "columns": ["sessaoId"]
        },
        "unidadeDosagemId": {
            "columns": ["unidadeDosagemId"]
        },
        "insumoLoteId": {
            "columns": ["insumoLoteId"]
        }
    }
}
