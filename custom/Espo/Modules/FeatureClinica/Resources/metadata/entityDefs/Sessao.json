{
    "fields": {
        "jornada": {
            "type": "link",
            "required": true
        },
        "sequencia": {
            "type": "int"
        },
        "status": {
            "type": "enum",
            "options": ["Pendente", "Agendada", "Realizada", "Expirada", "Cancelada"],
            "default": "Pendente",
            "style": {
                "Pendente": "default",
                "Agendada": "primary",
                "Realizada": "success",
                "Expirada": "warning",
                "Cancelada": "danger"
            },
            "audited": true
        },
        "procedimentoType": {
            "type": "varchar",
            "maxLength": 100
        },
        "procedimentoId": {
            "type": "foreignId"
        },
        "procedimento": {
            "type": "linkParent",
            "entityList": ["ProcedimentoConsulta", "ProcedimentoInjetavel", "ProcedimentoImplante", "ProcedimentoEstetico", "ProcedimentoAtividadeFisica"]
        },
        "appointment": {
            "type": "link"
        },
        "dosagemAplicada": {
            "type": "float"
        },
        "unidadeDosagem": {
            "type": "link"
        },
        "unidade": {
            "type": "link",
            "required": true
        },
        "insumoLote": {
            "type": "link"
        },
        "insumoLoteQuantidadeAtual": {
            "type": "varchar",
            "notStorable": true,
            "readOnly": true,
            "select": {
                "select": "CONCAT:(insumoLote.quantidadeAtual, ' ', insumoLoteInsumo.unidadeMedida)",
                "leftJoins": [
                    "insumoLote",
                    ["Insumo", "insumoLoteInsumo", {"insumoLoteInsumo.id:": "insumoLote.insumoId"}]
                ]
            }
        },
        "dosagemAplicadaFormatada": {
            "type": "varchar",
            "notStorable": true,
            "readOnly": true,
            "select": {
                "select": "CONCAT:(dosagemAplicada, ' ', unidadeDosagem.sigla)",
                "leftJoins": ["unidadeDosagem"]
            }
        },
        "dataExpiracao": {
            "type": "date"
        },
        "observacao": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams",
            "layoutRelationshipsDisabled": true
        }
    },
    "links": {
        "jornada": {
            "type": "belongsTo",
            "entity": "Jornada",
            "foreign": "sessoes",
            "foreignName": "nome"
        },
        "procedimento": {
            "type": "belongsToParent"
        },
        "appointment": {
            "type": "belongsTo",
            "entity": "Appointment"
        },
        "unidade": {
            "type": "belongsTo",
            "entity": "Unidade",
            "foreignName": "nome"
        },
        "unidadeDosagem": {
            "type": "belongsTo",
            "entity": "UnidadeDosagem",
            "foreignName": "nome"
        },
        "insumoLote": {
            "type": "belongsTo",
            "entity": "InsumoLote",
            "foreignName": "numeroLote"
        },
        "procedimentosRealizados": {
            "type": "hasMany",
            "entity": "ProcedimentoRealizado",
            "foreign": "sessao"
        },
        "consumoItens": {
            "type": "hasMany",
            "entity": "ConsumoInsumo",
            "foreign": "sessao"
        },
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        }
    },
    "collection": {
        "orderBy": "sequencia",
        "order": "asc"
    },
    "indexes": {
        "procedimento": {
            "columns": ["procedimentoType", "procedimentoId"]
        },
        "jornadaId": {
            "columns": ["jornadaId"]
        },
        "appointmentId": {
            "columns": ["appointmentId"]
        },
        "unidadeId": {
            "columns": ["unidadeId"]
        },
        "unidadeDosagemId": {
            "columns": ["unidadeDosagemId"]
        },
        "insumoLoteId": {
            "columns": ["insumoLoteId"]
        }
    }
}
