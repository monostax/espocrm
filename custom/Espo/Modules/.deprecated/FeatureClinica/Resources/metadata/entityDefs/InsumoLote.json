{
    "fields": {
        "name": {
            "type": "varchar",
            "notStorable": true,
            "readOnly": true,
            "select": {
                "select": "numeroLote"
            },
            "selectForeign": {
                "select": "{alias}.numeroLote"
            },
            "order": {
                "order": [["numeroLote", "{direction}"]]
            }
        },
        "insumo": {
            "type": "link",
            "required": true
        },
        "unidade": {
            "type": "link",
            "required": true
        },
        "numeroLote": {
            "type": "varchar",
            "required": true,
            "maxLength": 100,
            "trim": true
        },
        "dataFabricacao": {
            "type": "date"
        },
        "dataValidade": {
            "type": "date",
            "required": true
        },
        "quantidadeAquisicao": {
            "type": "float",
            "required": true,
            "view": "feature-clinica:views/fields/quantidade-aquisicao"
        },
        "quantidadeAtual": {
            "type": "float"
        },
        "insumoTipo": {
            "type": "foreign",
            "link": "insumo",
            "field": "tipo",
            "readOnly": true
        },
        "insumoUnidadeAquisicao": {
            "type": "foreign",
            "link": "insumo",
            "field": "unidadeAquisicao",
            "readOnly": true
        },
        "insumoQuantidadePorUnidade": {
            "type": "foreign",
            "link": "insumo",
            "field": "quantidadePorUnidade",
            "readOnly": true
        },
        "insumoApresentacao": {
            "type": "foreign",
            "link": "insumo",
            "field": "apresentacao",
            "readOnly": true
        },
        "insumoUnidadeDosagem": {
            "type": "foreign",
            "link": "insumo",
            "field": "unidadeDosagem",
            "readOnly": true
        },
        "insumoVolumeTotal": {
            "type": "foreign",
            "link": "insumo",
            "field": "volumeTotal",
            "readOnly": true
        },
        "insumoDosagemTotal": {
            "type": "foreign",
            "link": "insumo",
            "field": "dosagemTotal",
            "readOnly": true
        },
        "insumoConcentracao": {
            "type": "foreign",
            "link": "insumo",
            "field": "concentracao",
            "readOnly": true
        },
        "saldoMg": {
            "type": "float",
            "audited": true
        },
        "saldoMl": {
            "type": "float",
            "audited": true
        },
        "saldoMgFormatado": {
            "type": "varchar",
            "notStorable": true,
            "readOnly": true,
            "select": {
                "select": "CONCAT:(saldoMg, ' ', insumo.unidadeDosagem)",
                "leftJoins": ["insumo"]
            }
        },
        "saldoMlFormatado": {
            "type": "varchar",
            "notStorable": true,
            "readOnly": true,
            "select": {
                "select": "CONCAT:(saldoMl, ' mL')",
                "leftJoins": []
            }
        },
        "statusUso": {
            "type": "enum",
            "options": ["Nova", "EmUso", "Esgotada"],
            "audited": true
        },
        "sessoesUsadas": {
            "type": "int",
            "default": 0
        },
        "modalidadeUso": {
            "type": "enum",
            "options": ["Coletivo", "Exclusivo"]
        },
        "jornadaId": {
            "type": "varchar",
            "maxLength": 24
        },
        "saldoFormatado": {
            "type": "varchar",
            "notStorable": true,
            "readOnly": true,
            "select": {
                "select": "CONCAT:(quantidadeAtual, ' ', insumo.apresentacao)",
                "leftJoins": ["insumo"]
            }
        },
        "fornecedor": {
            "type": "varchar",
            "maxLength": 255,
            "trim": true
        },
        "notaFiscal": {
            "type": "varchar",
            "maxLength": 100,
            "trim": true
        },
        "precoUnitarioCusto": {
            "type": "currency"
        },
        "status": {
            "type": "enum",
            "required": true,
            "options": ["Disponivel", "Vencido", "Esgotado", "Bloqueado"],
            "default": "Disponivel"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams",
            "layoutRelationshipsDisabled": true
        }
    },
    "links": {
        "insumo": {
            "type": "belongsTo",
            "entity": "Insumo",
            "foreignName": "nome"
        },
        "unidade": {
            "type": "belongsTo",
            "entity": "Unidade",
            "foreignName": "nome"
        },
        "movimentacoes": {
            "type": "hasMany",
            "entity": "MovimentacaoEstoque",
            "foreign": "insumoLote"
        },
        "sessoes": {
            "type": "hasMany",
            "entity": "Sessao",
            "foreign": "insumoLote"
        },
        "procedimentosRealizados": {
            "type": "hasMany",
            "entity": "ProcedimentoRealizado",
            "foreign": "insumoLote"
        },
        "consumoItens": {
            "type": "hasMany",
            "entity": "ConsumoInsumo",
            "foreign": "insumoLote"
        },
        "jornada": {
            "type": "belongsTo",
            "entity": "Jornada",
            "foreignName": "nome",
            "foreign": "lotesExclusivos"
        },
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        }
    },
    "collection": {
        "orderBy": "dataValidade",
        "order": "asc",
        "textFilterFields": ["numeroLote", "fornecedor"]
    },
    "indexes": {
        "insumoId": {
            "columns": ["insumoId"]
        },
        "unidadeId": {
            "columns": ["unidadeId"]
        },
        "status": {
            "columns": ["status"]
        },
        "dataValidade": {
            "columns": ["dataValidade"]
        },
        "numeroLote": {
            "columns": ["numeroLote"]
        },
        "statusUso": {
            "columns": ["statusUso"]
        },
        "modalidadeUso": {
            "columns": ["modalidadeUso"]
        },
        "jornadaId": {
            "columns": ["jornadaId"]
        },
        "statusStatusUso": {
            "columns": ["status", "statusUso"]
        }
    }
}

