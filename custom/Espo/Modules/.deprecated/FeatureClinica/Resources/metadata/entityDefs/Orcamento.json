            "foreign": "orcamentoOrigem"
        },
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc",
        "textFilterFields": ["numero"]
    },
    "indexes": {
        "pacienteId": {
            "columns": ["pacienteId"]
        },
        "unidadeId": {
            "columns": ["unidadeId"]
        },
        "convenioId": {
            "columns": ["convenioId"]
        },
        "programaId": {
            "columns": ["programaId"]
        },
        "status": {
            "columns": ["status"]
        },
        "dataValidade": {
            "columns": ["dataValidade"]
        },
        "numero": {
            "columns": ["numero"]
        }
    },
    "cascadeDelete": {
        "links": ["itens"]
    }
}

