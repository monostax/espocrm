{
    "fields": {
        "name": {
            "type": "varchar",
            "notStorable": true,
            "readOnly": true,
            "select": {
                "select": "numero"
            },
            "selectForeign": {
                "select": "{alias}.numero"
            },
            "order": {
                "order": [["numero", "{direction}"]]
            }
        },
        "paciente": {
            "type": "link",
            "required": true
        },
        "profissional": {
            "type": "link"
        },
        "unidade": {
            "type": "link",
            "required": true
        },
        "convenio": {
            "type": "link"
        },
        "numero": {
            "type": "varchar",
            "required": true,
            "maxLength": 20,
            "trim": true
        },
        "versao": {
            "type": "int",
            "required": true,
            "default": 1
        },
        "orcamentoOrigem": {
            "type": "link"
        },
        "programa": {
            "type": "link"
        },
        "status": {
            "type": "enum",
            "required": true,
            "options": [
                "Rascunho",
                "Enviado",
                "Aprovado",
                "Expirado",
                "Recusado"
            ],
            "default": "Rascunho",
            "style": {
                "Rascunho": "default",
                "Enviado": "primary",
                "Aprovado": "success",
                "Expirado": "warning",
                "Recusado": "danger"
            },
            "audited": true
        },
        "dataEmissao": {
            "type": "date",
            "required": true
        },
        "dataValidade": {
            "type": "date",
            "required": true
        },
        "valorTotal": {
            "type": "currency",
            "required": true
        },
        "valorDesconto": {
            "type": "currency"
        },
        "valorLiquido": {
            "type": "currency",
            "required": true
        },
        "autorizadoPor": {
            "type": "link"
        },
        "observacoes": {
            "type": "text"
        },
        "motivoRecusa": {
            "type": "text"
        },
        "jornada": {
            "type": "link"
        },
        "lancamento": {
            "type": "link"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams",
            "layoutRelationshipsDisabled": true
        }
    },
    "links": {
        "paciente": {
            "type": "belongsTo",
            "entity": "Paciente",
            "foreign": "orcamentos"
        },
        "profissional": {
            "type": "belongsTo",
            "entity": "Profissional",
            "foreignName": "nome"
        },
        "unidade": {
            "type": "belongsTo",
            "entity": "Unidade",
            "foreignName": "nome"
        },
        "convenio": {
            "type": "belongsTo",
            "entity": "Convenio",
            "foreignName": "nome"
        },
        "orcamentoOrigem": {
            "type": "belongsTo",
            "entity": "Orcamento",
            "foreign": "versoes",
            "foreignName": "numero"
        },
        "autorizadoPor": {
            "type": "belongsTo",
            "entity": "Profissional",
            "foreignName": "nome"
        },
        "programa": {
            "type": "belongsTo",
            "entity": "Programa",
            "foreignName": "nome"
        },
        "jornada": {
            "type": "belongsTo",
            "entity": "Jornada",
            "foreign": "orcamentos",
            "foreignName": "nome"
        },
        "lancamento": {
            "type": "belongsTo",
            "entity": "LancamentoFinanceiro",
            "foreignName": "id"
        },
        "itens": {
            "type": "hasMany",
            "entity": "OrcamentoItem",
            "foreign": "orcamento"
        },
        "versoes": {
            "type": "hasMany",
