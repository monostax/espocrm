{
    "controller": "controllers/record",
    "iconClass": "fas fa-file-invoice-dollar",
    "nameAttribute": "numero",
    "dynamicHandler": "feature-clinica:dynamic-handlers/orcamento",
    "kanbanViewMode": true,
    "kanbanStatusField": "status",
    "listDefaultViewMode": "kanban",
    "listViewModeList": ["list", "kanban"],
    "viewModeIconClassMap": {
        "list": "fas fa-align-justify",
        "kanban": "fas fa-columns"
    },
    "recordViews": {
        "kanban": "feature-clinica:views/orcamento/record/kanban"
    },
    "defaultSidePanelFieldLists": {
        "detail": ["status", "paciente", "unidade", "profissional", "convenio", "teams", "createdAt", "modifiedAt"],
        "edit": ["teams"],
        "detailSmall": ["teams"]
    },
    "relationshipPanels": {
        "itens": {
            "create": true,
            "select": false
        }
    },
    "filterList": ["status", "unidade", "convenio"],
    "dynamicLogic": {
        "fields": {
            "motivoRecusa": {
                "visible": {
                    "conditionGroup": [
                        {
                            "type": "equals",
                            "attribute": "status",
                            "value": "Recusado"
                        }
                    ]
                }
            },
            "autorizadoPor": {
                "required": {
                    "conditionGroup": [
                        {
                            "type": "isNotEmpty",
                            "attribute": "valorDesconto"
                        }
                    ]
                }
            },
            "jornada": {
                "readOnly": {
                    "conditionGroup": []
                }
            },
            "lancamento": {
                "readOnly": {
                    "conditionGroup": []
                }
            },
            "paciente": {
                "readOnly": {
                    "conditionGroup": [
                        {
                            "type": "in",
                            "attribute": "status",
                            "value": ["Aprovado", "Expirado", "Recusado"]
                        }
                    ]
                }
            },
            "profissional": {
                "readOnly": {
                    "conditionGroup": [
                        {
                            "type": "in",
                            "attribute": "status",
                            "value": ["Aprovado", "Expirado", "Recusado"]
                        }
                    ]
                }
            },
            "unidade": {
                "readOnly": {
                    "conditionGroup": [
                        {
                            "type": "in",
                            "attribute": "status",
                            "value": ["Aprovado", "Expirado", "Recusado"]
                        }
                    ]
                }
            },
            "convenio": {
                "readOnly": {
                    "conditionGroup": [
                        {
                            "type": "in",
                            "attribute": "status",
                            "value": ["Aprovado", "Expirado", "Recusado"]
                        }
                    ]
                }
            },
            "programa": {
                "readOnly": {
                    "conditionGroup": [
                        {
                            "type": "in",
                            "attribute": "status",
                            "value": ["Aprovado", "Expirado", "Recusado"]
                        }
                    ]
                }
            },
            "valorTotal": {
                "readOnly": {
                    "conditionGroup": [
                        {
                            "type": "in",
                            "attribute": "status",
                            "value": ["Aprovado", "Expirado", "Recusado"]
                        }
                    ]
                }
            },
            "valorDesconto": {
                "readOnly": {
                    "conditionGroup": [
                        {
                            "type": "in",
                            "attribute": "status",
                            "value": ["Aprovado", "Expirado", "Recusado"]
                        }
                    ]
                }
            },
            "valorLiquido": {
                "readOnly": {
                    "conditionGroup": [
                        {
                            "type": "in",
                            "attribute": "status",
                            "value": ["Aprovado", "Expirado", "Recusado"]
                        }
                    ]
                }
            }
        }
    }
}
